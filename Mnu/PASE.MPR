DEFINE PAD _31w0tks6z OF _MSYSMENU PROMPT "Salir" COLOR SCHEME 3 ;
	KEY ALT+S, ""
DEFINE PAD _31w0tks70 OF _MSYSMENU PROMPT "Tablas" COLOR SCHEME 3 ;
	KEY ALT+T, ""
DEFINE PAD _31w0tks71 OF _MSYSMENU PROMPT "Pase de Guardia" COLOR SCHEME 3 ;
