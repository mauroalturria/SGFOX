SET SYSMENU TO
SET SYSMENU AUTOMATIC

DEFINE PAD _1hh0vjzv5 OF _MSYSMENU PROMPT "Salir" COLOR SCHEME 3 ;
	KEY ALT+S, ""
DEFINE PAD _1hh0vjzvc OF _MSYSMENU PROMPT "Mesa de Admision" COLOR SCHEME 3 ;
	KEY ALT+M, ""
DEFINE PAD _1hh0vjzvd OF _MSYSMENU PROMPT "Admisión" COLOR SCHEME 3 ;
	KEY ALT+A, ""
DEFINE PAD _1hh0vjzve OF _MSYSMENU PROMPT "Guardia" COLOR SCHEME 3 ;
	KEY ALT+G, ""
DEFINE PAD _1hh0vjzvf OF _MSYSMENU PROMPT "Archivo" COLOR SCHEME 3 ;
	KEY ALT+A, ""
DEFINE PAD _1hh0vjzvg OF _MSYSMENU PROMPT "Turnos" COLOR SCHEME 3 ;
	KEY ALT+T, ""
DEFINE PAD _1hh0vjzvh OF _MSYSMENU PROMPT "Estadisticas Generales" COLOR SCHEME 3 ;
	KEY ALT+E, ""
DEFINE PAD _1hh0vjzvi OF _MSYSMENU PROMPT "Contraseńa" COLOR SCHEME 3 ;
	KEY ALT+C, ""
ON PAD _1hh0vjzv5 OF _MSYSMENU ACTIVATE POPUP salir
ON PAD _1hh0vjzvd OF _MSYSMENU ACTIVATE POPUP admisión
ON PAD _1hh0vjzve OF _MSYSMENU ACTIVATE POPUP guardia
ON PAD _1hh0vjzvf OF _MSYSMENU ACTIVATE POPUP archivo
ON PAD _1hh0vjzvg OF _MSYSMENU ACTIVATE POPUP turnos
ON PAD _1hh0vjzvh OF _MSYSMENU ACTIVATE POPUP estadistic
ON PAD _1hh0vjzvi OF _MSYSMENU ACTIVATE POPUP password

DEFINE POPUP salir MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF salir PROMPT "Cerrar aplicacion"
ON SELECTION BAR 1 OF salir quit

DEFINE POPUP admisión MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF admisión PROMPT "Pacientes Internados" ;
	SKIP FOR type('mfrmadmision01') = 'U'
ON SELECTION BAR 1 OF admisión do form frmadmision01

DEFINE POPUP guardia MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF guardia PROMPT "Ingreso de Pacientes" ;
	SKIP FOR type('mfrmguardia01') = 'U'
