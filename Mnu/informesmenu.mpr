	SKIP FOR type('mfrmguardia23') = 'U'
DEFINE BAR 6 OF guardia PROMPT "Consulta mensual" ;
	SKIP FOR type('mfrmguardia18') = 'U'
ON SELECTION BAR 1 OF guardia do form frmguardia01
ON SELECTION BAR 2 OF guardia do form frmguardia03 with 1
ON SELECTION BAR 3 OF guardia do form frmguardia03 with 2
ON SELECTION BAR 5 OF guardia do form frmguardia23
ON SELECTION BAR 6 OF guardia do form frmguardia18

