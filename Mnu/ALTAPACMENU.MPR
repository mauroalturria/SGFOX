	KEY ALT+S, ""
DEFINE PAD _73u0xxuq5 OF _MSYSMENU PROMPT "Ingresos" COLOR SCHEME 3 ;
	KEY ALT+I, ""
DEFINE PAD _73u0xxuq6 OF _MSYSMENU PROMPT "Consultas" COLOR SCHEME 3 ;
