SET SYSMENU TO
SET SYSMENU AUTOMATIC

DEFINE PAD _7aa0jwnla OF _MSYSMENU PROMPT "Salir" COLOR SCHEME 3 ;
	KEY ALT+S, ""
DEFINE PAD _7aa0jwnlb OF _MSYSMENU PROMPT "Administracion" COLOR SCHEME 3 ;
	KEY ALT+A, ""
DEFINE PAD _7aa0jwnlq OF _MSYSMENU PROMPT "Listados y Consultas" COLOR SCHEME 3 ;
	KEY ALT+L, ""
DEFINE PAD _7aa0jwnlr OF _MSYSMENU PROMPT "Usuario" COLOR SCHEME 3 ;
	KEY ALT+U, ""
ON PAD _7aa0jwnla OF _MSYSMENU ACTIVATE POPUP salir
ON PAD _7aa0jwnlb OF _MSYSMENU ACTIVATE POPUP administra
ON PAD _7aa0jwnlq OF _MSYSMENU ACTIVATE POPUP listadosyc
ON PAD _7aa0jwnlr OF _MSYSMENU ACTIVATE POPUP modificaci

DEFINE POPUP salir MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF salir PROMPT "Cerrar Aplicacion"
DEFINE BAR 2 OF salir PROMPT "Acerca de..."
ON SELECTION BAR 1 OF salir ;
	DO _7aa0jwnls ;
	IN LOCFILE("MNU\CIAMMENU" ,"MPX;MPR|FXP;PRG" ,"WHERE is CIAMMENU?")
ON SELECTION BAR 2 OF salir do form frmacercade

DEFINE POPUP administra MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF administra PROMPT "C.U.D. (Centro Unico de Derivación)"
DEFINE BAR 2 OF administra PROMPT "Auditorías de Internación"
DEFINE BAR 3 OF administra PROMPT "Centros Asistenciales"
ON SELECTION BAR 1 OF administra do form frmciam01
ON SELECTION BAR 2 OF administra do form frmciam19
ON SELECTION BAR 3 OF administra do form frmciam14 with 1

DEFINE POPUP listadosyc MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF listadosyc PROMPT "Derivaciones por Entidad"
DEFINE BAR 2 OF listadosyc PROMPT "Auditoría de Internación"
DEFINE BAR 3 OF listadosyc PROMPT "Derivaciones - Gral"
ON SELECTION BAR 1 OF listadosyc do form frmciam18
ON SELECTION BAR 2 OF listadosyc do form frmciam26
ON SELECTION BAR 3 OF listadosyc do form frmciam15 with 1

DEFINE POPUP modificaci MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF modificaci PROMPT "Cambio de Password"
ON SELECTION BAR 1 OF modificaci do form frmpass_amb


