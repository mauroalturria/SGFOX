SET SYSMENU TO
SET SYSMENU AUTOMATIC

DEFINE PAD _7a112lsup OF _MSYSMENU PROMPT "Salir" COLOR SCHEME 3 ;
	KEY ALT+S, ""
DEFINE PAD _7a112lsuq OF _MSYSMENU PROMPT "Farmacia" COLOR SCHEME 3 ;
	KEY ALT+F, ""
