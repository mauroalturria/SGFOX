	KEY ALT+U, ""
ON PAD _7a112lsup OF _MSYSMENU ACTIVATE POPUP salir
ON PAD _7a112lsuq OF _MSYSMENU ACTIVATE POPUP farmacia
ON PAD _7a112lsur OF _MSYSMENU ACTIVATE POPUP _31v0ln9j3
ON PAD _7a112lsus OF _MSYSMENU ACTIVATE POPUP listadosyc
ON PAD _7a112lsut OF _MSYSMENU ACTIVATE POPUP sap
ON PAD _7a112lsuu OF _MSYSMENU ACTIVATE POPUP modificaci

DEFINE POPUP salir MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF salir PROMPT "Cerrar Aplicacion"
DEFINE BAR 2 OF salir PROMPT "Acerca de..."
ON SELECTION BAR 1 OF salir ;
	DO _7a112lsuv ;
	IN LOCFILE("MNU\FARMACIAMENU" ,"MPX;MPR|FXP;PRG" ,"WHERE is FARMACIAMENU?")
ON SELECTION BAR 2 OF salir do form frmacercade

DEFINE POPUP farmacia MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF farmacia PROMPT "Etiquetas de Fraccionamiento" ;
	SKIP FOR type('mfrmfarmacia01') = 'U'
DEFINE BAR 2 OF farmacia PROMPT "Auditoria de Insumos - Descripciones" ;
	SKIP FOR type('mfrmfarmacia05') = 'U'
DEFINE BAR 3 OF farmacia PROMPT "Recepción / Trazabilidad"
DEFINE BAR 4 OF farmacia PROMPT "Vales Paciente"
ON SELECTION BAR 1 OF farmacia do form frmfarmacia01
ON SELECTION BAR 2 OF farmacia do form frmfarmacia05
ON BAR 3 OF farmacia ACTIVATE POPUP recepciónt
ON BAR 4 OF farmacia ACTIVATE POPUP valespacie

DEFINE POPUP recepciónt MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF recepciónt PROMPT "Recepción del Producto"
