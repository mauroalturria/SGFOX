DEFINE BAR 13 OF listadosyc PROMPT "\-"
DEFINE BAR 14 OF listadosyc PROMPT "Cirugías sin Alta Complejidad" ;
	SKIP FOR type('mfrmquirof01') = 'U'
ON SELECTION BAR 1 OF listadosyc do form frmquirof02
