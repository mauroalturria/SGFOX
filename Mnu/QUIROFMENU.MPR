DEFINE BAR 3 OF actualizac PROMPT "Pacientes Hemoterapia" ;
	SKIP FOR type('mfrmquirof10') = 'U'
DEFINE BAR 4 OF actualizac PROMPT "Material Quirúrgico" ;
	SKIP FOR type('mfrmquirof10') = 'U'
DEFINE BAR 5 OF actualizac PROMPT "Parte Quirúrgico CPC" ;
	SKIP FOR type('mfrmquirof01cpc') = 'U'
DEFINE BAR 6 OF actualizac PROMPT "Parte Endoscópico CPC" ;
	SKIP FOR type('mfrmquirof01cpc') = 'U'
DEFINE BAR 7 OF actualizac PROMPT "Protocolos de HEMODINAMIA" ;
	SKIP FOR type('mfrmquirof10HD') = 'U'
DEFINE BAR 8 OF actualizac PROMPT "\-"
DEFINE BAR 9 OF actualizac PROMPT "Asignacion de Mesas / Bandejas" ;
	SKIP FOR type('mfrmquirof10a') = 'U'
DEFINE BAR 10 OF actualizac PROMPT "Impresión de Bolsas" ;
	SKIP FOR type('mfrmquirof14') = 'U'
