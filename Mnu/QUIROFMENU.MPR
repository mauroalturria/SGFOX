SET SYSMENU TO
SET SYSMENU AUTOMATIC

DEFINE PAD _7gr0sivhw OF _MSYSMENU PROMPT "Salir" COLOR SCHEME 3 ;
	KEY ALT+S, ""
DEFINE PAD _7gr0sivhx OF _MSYSMENU PROMPT "Actualizaciones" COLOR SCHEME 3 ;
	KEY ALT+A, ""
DEFINE PAD _7gr0sivhy OF _MSYSMENU PROMPT "Listados y Consultas" COLOR SCHEME 3 ;
	KEY ALT+L, ""
DEFINE PAD _7gr0sivhz OF _MSYSMENU PROMPT "Documentación" COLOR SCHEME 3 ;
	KEY ALT+D, ""
DEFINE PAD _7gr0sivi0 OF _MSYSMENU PROMPT "Usuario" COLOR SCHEME 3 ;
	KEY ALT+U, ""
ON PAD _7gr0sivhw OF _MSYSMENU ACTIVATE POPUP salir
ON PAD _7gr0sivhx OF _MSYSMENU ACTIVATE POPUP actualizac
ON PAD _7gr0sivhy OF _MSYSMENU ACTIVATE POPUP listadosyc
ON PAD _7gr0sivhz OF _MSYSMENU ACTIVATE POPUP newitem
ON PAD _7gr0sivi0 OF _MSYSMENU ACTIVATE POPUP usuario

DEFINE POPUP salir MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF salir PROMPT "Cerrar Aplicacion"
DEFINE BAR 2 OF salir PROMPT "Acerca de..."
ON SELECTION BAR 1 OF salir ;
	DO _7gr0sivi1 ;
	IN LOCFILE("MNU\QUIROFMENU" ,"MPX;MPR|FXP;PRG" ,"WHERE is QUIROFMENU?")
ON SELECTION BAR 2 OF salir do form frmacercade

DEFINE POPUP actualizac MARGIN RELATIVE SHADOW COLOR SCHEME 4
