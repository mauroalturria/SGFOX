DEFINE BAR 14 OF actualizac PROMPT "Control de Prestadores" ;
	SKIP FOR type('mfrmquirof09') = 'U'
DEFINE BAR 15 OF actualizac PROMPT "\-"
DEFINE BAR 16 OF actualizac PROMPT "Gestion franjas Pre QX" ;
	SKIP FOR type('mfrmpreqx11') = 'U'
DEFINE BAR 17 OF actualizac PROMPT "Gestion de Pre QX de Internados" ;
	SKIP FOR type('mfrmquirof30') = 'U'
ON SELECTION BAR 1 OF actualizac do form frmquirof01
ON SELECTION BAR 2 OF actualizac do form frmquirof01 with ,,"ENDOSCOPIA"
ON SELECTION BAR 3 OF actualizac do form frmquirof10 with 1
ON SELECTION BAR 4 OF actualizac do form frmquirof10 with 2
