DEFINE POPUP salir MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF salir PROMPT "Salir del Sistema"
DEFINE BAR 2 OF salir PROMPT "Acerca de..."
ON SELECTION BAR 1 OF salir ;
	DO _742109ywk ;
	IN LOCFILE("MNU\AGENMED" ,"MPX;MPR|FXP;PRG" ,"WHERE is AGENMED?")
ON SELECTION BAR 2 OF salir do form frmacercade

DEFINE POPUP configurac MARGIN RELATIVE SHADOW COLOR SCHEME 4
DEFINE BAR 1 OF configurac PROMPT "Selección de Policonsultorio"
DEFINE BAR 2 OF configurac PROMPT "Cambio de \<Password" ;
	SKIP FOR left(mwkusuario.nomape,1)='*'
DEFINE BAR 3 OF configurac PROMPT "\<Usuario"
DEFINE BAR 4 OF configurac PROMPT "Mesa de Ayuda" ;
	SKIP FOR type('mfrmreclamos03') = 'U'
ON SELECTION BAR 1 OF configurac do form frmagen01
ON SELECTION BAR 2 OF configurac do form frmpass_amb
ON SELECTION BAR 3 OF configurac ;
	DO _742109yws ;
	IN LOCFILE("MNU\AGENMED" ,"MPX;MPR|FXP;PRG" ,"WHERE is AGENMED?")
ON SELECTION BAR 4 OF configurac Do form  frmreclamos03

DEFINE POPUP tablasvari MARGIN RELATIVE SHADOW COLOR SCHEME 4
