	SKIP FOR type('mfrmciam28') = 'U'
DEFINE BAR 6 OF censossg PROMPT "\-"
DEFINE BAR 7 OF censossg PROMPT "Relaciones (Entidad & Destinatario)" ;
	SKIP FOR type('mfrmciam29') = 'U'
ON SELECTION BAR 1 OF censossg do form frmciam27 with "CIAM"
ON SELECTION BAR 3 OF censossg do form frmciam30
ON SELECTION BAR 5 OF censossg do form frmciam28
ON SELECTION BAR 7 OF censossg do form frmciam29

